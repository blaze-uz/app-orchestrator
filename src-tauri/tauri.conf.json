{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Karvon",
  "version": "0.2.0",
  "identifier": "uz.blaze.karvon",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Karvon",
        "width": 1440,
        "height": 920,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGNEExMThDNTlBOEQ2MkIKUldRcjFxaFpqQkZLNzVPM1NHSGRYWlpSMzhlaW9NVDRRc3FVeU9QRmN4UXdtaW9IVUFRU2FrT08K",
      "endpoints": [
        "https://github.com/blaze-uz/karvon/releases/latest/download/latest.json"
      ]
    }
  }
}
