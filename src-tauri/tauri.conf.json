{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local Project Orchestrator",
  "version": "0.1.0",
  "identifier": "dev.local-project-orchestrator.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Local Project Orchestrator",
        "width": 1440,
        "height": 920,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg3MjNEM0FFRENFRDA3OEMKUldTTUIrM2NydE1qaDcrbzRGRnZjYzh2WDZTemdoQk5ITkl4cit4RnpPZU5YaXdCdEU0TldZVnkK",
      "endpoints": [
        "https://github.com/blaze-uz/app-orchestrator/releases/latest/download/latest.json"
      ]
    }
  }
}
